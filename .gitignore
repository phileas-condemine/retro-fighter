.venv/
__pycache__/
*.pyc
.DS_Store
.idea/
.vscode/

# Reference/mood-board images, not used by the game code.
inspiration_graphique/

# Source packs already extracted/integrated into assets/ — kept locally for
# re-processing if needed, not tracked once their content has been merged in.
*_pack.zip
*_pack_v*.zip

# Pygbag web build output — regenerated by .github/workflows/deploy-pygbag-pages.yml,
# not something to version.
build/

# Per-fight combat logs (retro_fighter/combat_log.py), local play data, not source.
logs/

# Claude Code session tooling state, not part of the project.
.claude/

# Blender v2 pipeline test fixtures (placeholder parts + their rendered
# output) — fully regenerable via blender/make_placeholder_parts.py +
# blender/run_pipeline.py, see blender/README.md.
blender/test_fixtures/

# Playwright MCP's own scratch output (screenshots, accessibility snapshots,
# console logs, downloaded zips) from driving a browser — not project
# source, see HOW_TO_GENERATE_IMAGES.md.
.playwright-mcp/
